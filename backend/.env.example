# ─────────────────────────────────────────────────────────────────────────────
# YouTube Hub Backend – Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# ─── YouTube Data API v3 ─────────────────────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_api_key_here

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# docker compose → DB_HOST=postgres   (matches the compose service name)
# local dev      → DB_HOST=localhost
DB_HOST=postgres
DB_PORT=5432
DB_NAME=youtube_db
DB_USER=postgres
DB_PASS=your_strong_password_here

# ─── n8n Webhook (optional) ──────────────────────────────────────────────────
N8N_WEBHOOK_URL=http://localhost:5678/webhook/youtube-events
N8N_API_KEY=your_n8n_api_key_here
WEBHOOK_SECRET=your_webhook_secret_here

# ─── Clerk (optional – for future server-side JWT verification) ───────────────
CLERK_SECRET_KEY=your_clerk_secret_key_here
