PORT=5000
NODE_ENV=development

# YouTube Data API v3
YOUTUBE_API_KEY=/* Youtube API */

# n8n webhook
N8N_WEBHOOK_URL=/* webhook URL */
# ─── PostgreSQL ───────────────────────────────────────────────────────────
# When running via docker compose, DB_HOST must be "postgres" (the service name).
# When running locally (no docker), use "localhost".
DB_HOST=postgres
DB_PORT=5432
DB_NAME=/* DB Name */
DB_USER=/*DB user */
DB_PASS=/*DB pass */
